---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 Not Found">
  <div class="max-w-3xl mx-auto px-6 py-32 text-center">
    <div class="font-mono text-violet-400 text-sm mb-4">Error: 404</div>
    <h1 class="text-5xl font-bold text-white mb-4">ページが見つかりません</h1>
    <p class="text-neutral-500 mb-8">お探しのページは存在しないか、移動した可能性があります。</p>
    <a href="/" class="inline-flex items-center gap-2 font-mono text-sm px-4 py-2 rounded border border-violet-700 text-violet-400 hover:bg-violet-950/50 transition-colors">
      ← ホームに戻る
    </a>
  </div>
</BaseLayout>
