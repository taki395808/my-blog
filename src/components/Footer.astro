---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-[#262626] mt-16">
  <div class="max-w-3xl mx-auto px-6 py-8 flex items-center justify-between text-sm text-neutral-500">
    <span class="font-mono">© {year} taki</span>
    <div class="flex items-center gap-4">
      <a href="https://github.com/taki395808" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
        GitHub
      </a>
      <a href={`${base}rss.xml`} class="hover:text-white transition-colors">
        RSS
      </a>
    </div>
  </div>
</footer>
