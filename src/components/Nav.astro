---
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: base, label: 'ホーム' },
  { href: `${base}blog`, label: 'ブログ' },
  { href: `${base}about`, label: '自己紹介' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[#262626] bg-[#0d0d0d]/90 backdrop-blur-sm">
  <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={base} class="font-mono text-sm font-medium text-white hover:text-violet-400 transition-colors">
      <span class="text-violet-400">~/</span>徒然なるままに綴る
    </a>
    <ul class="flex items-center gap-6">
      {navItems.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm transition-colors',
              currentPath === href || (href !== base && currentPath.startsWith(href))
                ? 'text-violet-400 font-medium'
                : 'text-neutral-400 hover:text-white'
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
